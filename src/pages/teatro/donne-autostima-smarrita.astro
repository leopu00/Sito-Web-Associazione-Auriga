---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Donne con l'autostima smarrita — Teatro — Auriga" headerTheme="light" pageNamespace="teatro-donne-autostima" pageClass="bg-[#faf7f2] text-black" pageBg="light" headerClass="bg-[#faf7f2]" headerStyle="background-color:#faf7f2">
  <section class="max-w-6xl mx-auto px-4 py-12 pt-20">

    <!-- Header -->
    <div class="text-center">
      <h1 class="text-3xl md:text-5xl font-bold">Donne con l'autostima smarrita</h1>
      <p class="mt-2 text-lg text-gray-600 italic">di Marilena Manfredi</p>
    </div>

    <!-- Locandina hero - cliccabile -->
    <div class="mt-8 flex justify-center">
      <div class="rounded-xl overflow-hidden shadow-lg max-w-lg cursor-pointer" onclick="openModal('/img/donne-autostima-smarrita/locandina.jpg')">
        <img src="/img/donne-autostima-smarrita/locandina.jpg" alt="Locandina dello spettacolo Donne con l'autostima smarrita" class="w-full h-auto hover:opacity-90 transition-opacity" />
      </div>
    </div>

    <!-- Data e Ingresso affiancati -->
    <div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="bg-gradient-to-br from-[#8B0000] to-[#5c0000] text-white rounded-xl p-6 shadow-lg text-center flex flex-col justify-center">
        <p class="text-sm uppercase tracking-wider opacity-80">Sabato 21 Marzo 2026</p>
        <p class="text-2xl font-bold mt-2">ore 21:00</p>
      </div>
      <div class="bg-white border border-gray-200 rounded-xl p-6 shadow-sm flex items-center">
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 bg-[#8B0000] rounded-full flex items-center justify-center flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z" />
            </svg>
          </div>
          <div>
            <p class="text-sm uppercase tracking-wider text-gray-500 font-medium">Ingresso</p>
            <p class="text-2xl font-bold text-gray-900">Gratuito</p>
            <p class="text-sm text-gray-500 mt-1">È gradito un libero apprezzamento</p>
          </div>
        </div>
      </div>
    </div>

    <!-- CTA Prenotazione -->
    <div class="mt-6 bg-[#8B0000] text-white rounded-xl p-8 text-center shadow-xl">
      <h3 class="text-2xl font-bold">Prenota il tuo posto!</h3>
      <p class="mt-2 text-white/90">Contattaci per prenotare via email o WhatsApp</p>
      <div class="mt-4 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="mailto:lefortunate5@gmail.com?subject=Prenotazione%20Donne%20con%20l'autostima%20smarrita%20-%2021%20Marzo&body=Salve,%0D%0AVorrei%20prenotare%20per%20lo%20spettacolo%20Donne%20con%20l'autostima%20smarrita%20del%2021%20Marzo.%0D%0A%0D%0ANumero%20persone:%0D%0A%0D%0AGrazie"
          class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-white text-[#8B0000] text-lg font-bold rounded-xl shadow-lg hover:bg-gray-100 transform hover:scale-105 transition-all duration-200"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          PRENOTA VIA EMAIL
        </a>
        <a
          href="https://wa.me/393479015115?text=Salve%2C%20vorrei%20prenotare%20per%20lo%20spettacolo%20%22Donne%20con%20l%27autostima%20smarrita%22%20del%2021%20Marzo.%20Grazie!"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-[#25D366] text-white text-lg font-bold rounded-xl shadow-lg hover:bg-[#1da851] transform hover:scale-105 transition-all duration-200"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          WHATSAPP
        </a>
      </div>
      <p class="mt-4 text-sm text-white/70">lefortunate5@gmail.com · +39 347 9015115</p>
    </div>

    <!-- Location con Mappa -->
    <h2 class="mt-10 text-2xl font-semibold flex items-center gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-[#8B0000]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
      </svg>
      Dove trovarci
    </h2>
    <div class="mt-4 bg-white rounded-xl shadow-lg overflow-hidden border border-gray-200">
      <div class="p-4 bg-gray-50 border-b">
        <p class="font-bold text-lg text-gray-900">Fondazione Culturasì — CAE Città dell'Altra Economia</p>
        <p class="text-gray-600">Largo Dino Frisullo SNC, 00153 Roma (Testaccio)</p>
        <a
          href="https://maps.app.goo.gl/pgMssPnHak2NKvts9"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1 mt-2 text-[#8B0000] hover:underline font-semibold"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
          Apri in Google Maps
        </a>
      </div>
      <iframe
        src="https://www.openstreetmap.org/export/embed.html?bbox=12.4720%2C41.8740%2C12.4760%2C41.8765&layer=mapnik&marker=41.8752%2C12.474"
        class="w-full h-64 md:h-80"
        style="border:0"
        loading="lazy"
        title="Mappa CAE Città dell'Altra Economia"
      ></iframe>
    </div>

    <!-- Lo Spettacolo -->
    <h2 class="mt-10 text-2xl font-semibold">Lo Spettacolo</h2>
    <p class="mt-3 leading-relaxed text-gray-700">
      <em>Donne con l'autostima smarrita</em> è uno spettacolo teatrale scritto da Marilena Manfredi che porta in scena cinque figure femminili alle prese con la ricerca della propria autostima. Un racconto corale, intenso e ironico, che esplora le fragilità e la forza delle donne contemporanee, accompagnato dalle note del sassofono dal vivo.
    </p>
    <p class="mt-3 leading-relaxed text-gray-700">
      Una produzione <strong>Delle Armi e degli Amori — Micro Teatro</strong>, in collaborazione con <strong>APS Auriga</strong> e <strong>Fondazione Culturasì</strong>.
    </p>

    <!-- Crediti e Cast -->
    <h2 class="mt-10 text-2xl font-semibold">Crediti e Cast</h2>
    <ul class="mt-3 space-y-1 text-gray-700">
      <li><strong>Testo:</strong> Marilena Manfredi</li>
      <li><strong>Regia:</strong> Rita Cecilia Rácz, Marilena Manfredi</li>
      <li><strong>Interpreti:</strong> Barbara Baffi, Antonella De Masi, Marilena Manfredi, Rita Cecilia Rácz, Alida Rota</li>
      <li><strong>Progetto Luci:</strong> Barbara Mugnai</li>
      <li><strong>Al Sax:</strong> Luigi Colucci</li>
    </ul>

    <!-- Info prenotazioni -->
    <div class="mt-10 bg-gray-50 border border-gray-200 rounded-xl p-6">
      <h3 class="text-lg font-semibold text-gray-900">Prenotazioni</h3>
      <div class="mt-3 space-y-2 text-gray-700">
        <p class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          <a href="mailto:lefortunate5@gmail.com" class="text-[#8B0000] hover:underline font-medium">lefortunate5@gmail.com</a>
        </p>
        <p class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          <a href="https://wa.me/393479015115" target="_blank" rel="noopener noreferrer" class="text-[#8B0000] hover:underline font-medium">+39 347 9015115</a>
          <span class="text-sm text-gray-500">(WhatsApp)</span>
        </p>
      </div>
    </div>

    <!-- CTA bottom -->
    <div class="mt-12 flex flex-wrap gap-3">
      <a href="/teatro" class="inline-block px-5 py-3 border border-black text-black rounded hover:bg-black hover:text-white transition-colors">
        ← Indietro
      </a>
      <a href="/eventi" class="inline-block px-5 py-3 bg-[#8B0000] text-white rounded hover:bg-[#6B0000] transition-colors">
        Tutti gli eventi
      </a>
    </div>

    <!-- Modal per locandina -->
    <div id="imgModal" class="fixed inset-0 bg-black/90 hidden items-center justify-center z-50" onclick="closeModal()">
      <img id="modalImg" src="" alt="Locandina a schermo intero" class="max-w-full max-h-full object-contain p-4" />
      <button onclick="closeModal()" class="absolute top-4 right-4 text-white text-3xl hover:text-gray-300">&times;</button>
    </div>
  </section>

  <script is:inline>
    function openModal(src) {
      const modal = document.getElementById('imgModal');
      const modalImg = document.getElementById('modalImg');
      modalImg.src = src;
      modal.classList.remove('hidden');
      modal.classList.add('flex');
    }

    function closeModal() {
      const modal = document.getElementById('imgModal');
      modal.classList.add('hidden');
      modal.classList.remove('flex');
    }

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') closeModal();
    });
  </script>
</BaseLayout>
